// ==UserScript==
// @name         Roll20 Chat Font Resizer
// @namespace    http://tampermonkey.net/
// @version      1.2
// @description  Roll20 채팅창 글자 크기 조절 (리셋 버튼 추가)
// @author       Hamzza
// @match        https://app.roll20.net/editor*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    const INITIAL_SIZE = 1.05; // 초기값 변수화
    let currentFontSize = INITIAL_SIZE;

    // 버튼 CSS 스타일
    const style = document.createElement('style');
    style.innerHTML = `
        #r20-font-ctrl {
            position: fixed;
            bottom: 14px;
            right: 6px;
            z-index: 10000;
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2px;
            background: #eee;
            padding: 4px;
            border: 1px solid #999;
            border-radius: 4px;
        }
        .r20-btn {
            width: 16px;
            height: 16px;
            cursor: pointer;
            border: 1px solid #666;
            background: #fff;
            font-weight: bold;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 2px;
        }
        /* 리셋 버튼 */
        .r20-btn-reset {
            width: auto;
            padding: 0 4px;
            font-size: 9px;
            color: #d11;
        }
        .r20-btn:hover { background: #eee; border-color: #000; }
        .r20-label {
            font-size: 10px;
            font-weight: bold;
            margin-right: 5px;
            color: #333;
            user-select: none;
            display: none;
        }

        .textchatcontainer .message {
            font-size: var(--r20-chat-size, 1.05em);
            line-height: 1.5;
        }
    `;
    document.head.appendChild(style);

    const updateFontSize = (newSize) => {
        currentFontSize = Math.round(newSize * 100) / 100;
        if (currentFontSize < 0.5) currentFontSize = 0.5;
        if (currentFontSize > 2.5) currentFontSize = 2.5;

        document.documentElement.style.setProperty('--r20-chat-size', currentFontSize + 'em');
    };

    const initUI = () => {
        // 중복 실행 방지
        if (document.getElementById('r20-font-ctrl')) return;

        // 채팅탭에서만 UI 노출
        const isMainChatWindow = document.querySelector('#textchat');
        if (!isMainChatWindow) return;

        const container = document.createElement('div');
        container.id = 'r20-font-ctrl';

        /* 라벨 스타일
        const label = document.createElement('span');
        label.className = 'r20-label';
        label.innerText = '글자';
        container.appendChild(label);
        */

        const minusBtn = document.createElement('button');
        minusBtn.className = 'r20-btn';
        minusBtn.innerText = '-';
        minusBtn.onclick = () => updateFontSize(currentFontSize - 0.05);

        const plusBtn = document.createElement('button');
        plusBtn.className = 'r20-btn';
        plusBtn.innerText = '+';
        plusBtn.onclick = () => updateFontSize(currentFontSize + 0.05);

        const resetBtn = document.createElement('button');
        resetBtn.className = 'r20-btn r20-btn-reset';
        resetBtn.innerText = 'R';
        resetBtn.title = '기본 크기로 리셋';
        resetBtn.onclick = () => updateFontSize(INITIAL_SIZE);

        container.appendChild(minusBtn);
        container.appendChild(plusBtn);
        container.appendChild(resetBtn);

        document.body.appendChild(container);
    };

    setTimeout(initUI, 3000);
})();
